---
import Layout from '../../layouts/Layout.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getCollection, render } from 'astro:content';
import {
  getPublishedPosts,
  getReadingTime,
  getPostUrl,
  getOgImageUrl,
  getRelatedPosts,
} from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const readingTime = getReadingTime(post.body);
const canonicalURL = new URL(getPostUrl(post), Astro.site).href;
const ogImage = getOgImageUrl(post, Astro.site!);

const allPosts = getPublishedPosts(await getCollection('blog'));
const currentIndex = allPosts.findIndex((entry) => entry.id === post.id);
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const relatedPosts = getRelatedPosts(post, allPosts);

const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<Layout
  title={`${post.data.title} // Noir Trace Writeups`}
  description={post.data.description}
  image={ogImage}
  canonicalURL={canonicalURL}
>
  <article class="max-w-4xl mx-auto" data-pagefind-body>
    <div class="mb-8 font-sans text-[10px] uppercase" data-pagefind-ignore>
      <a href="/blog/" class="text-text-secondary hover:text-white transition-colors">
        &larr; [ Back to database ]
      </a>
    </div>

    <header class="mb-8 pb-8 border-b border-neutral-900">
      <div class="flex items-center space-x-3 text-[10px] font-sans text-text-secondary uppercase mb-3" data-pagefind-ignore>
        <span>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        <span class="text-neutral-800">//</span>
        <span>{readingTime}</span>
        <span class="text-neutral-800">//</span>
        <span class="text-accent">{post.data.category}</span>
      </div>

      <h1 class="font-display font-bold text-2xl md:text-4xl text-white tracking-tight mb-4 leading-tight">
        {post.data.title}
      </h1>

      {post.data.cover_image && (
        <figure class="mb-6" data-pagefind-ignore>
          <img
            src={post.data.cover_image}
            alt=""
            width="1200"
            height="630"
            loading="lazy"
            decoding="async"
            class="w-full rounded-sm border border-neutral-900 object-cover max-h-[420px]"
          />
        </figure>
      )}

      <div class="flex flex-wrap gap-1.5" data-pagefind-ignore>
        {post.data.tags.map((tag) => (
          <span class="bg-bg-dark border border-neutral-800 text-[10px] font-sans px-2 py-0.5 text-text-secondary rounded-sm">
            #{tag}
          </span>
        ))}
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      {toc.length > 0 && (
        <aside class="hidden lg:block lg:col-span-1" data-pagefind-ignore>
          <div class="sticky top-24 space-y-4">
            <h3 class="font-display font-bold text-[10px] uppercase tracking-widest text-text-secondary border-b border-neutral-900 pb-2">
              Outline
            </h3>
            <nav class="space-y-2 font-sans text-[11px]">
              {toc.map((item) => (
                <a
                  href={`#${item.slug}`}
                  class={`block text-text-secondary hover:text-white transition-colors leading-relaxed ${
                    item.depth === 3 ? 'pl-3 text-[10px] text-neutral-500' : ''
                  }`}
                >
                  <span class="text-accent">{item.depth === 2 ? '>' : '>>'}</span> {item.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}

      <div class={`lg:col-span-3 ${toc.length === 0 ? 'lg:col-start-2' : ''}`}>
        {toc.length > 0 && (
          <details class="lg:hidden mb-6 border border-neutral-800 bg-surface/30 p-4 rounded-sm font-sans text-xs" data-pagefind-ignore>
            <summary class="cursor-pointer font-display font-bold uppercase tracking-wider text-neutral-300">
              Show Article Outline
            </summary>
            <nav class="mt-3 space-y-2 pl-2 border-l border-neutral-800">
              {toc.map((item) => (
                <a
                  href={`#${item.slug}`}
                  class={`block text-text-secondary hover:text-white transition-colors ${
                    item.depth === 3 ? 'pl-3 text-neutral-500' : ''
                  }`}
                >
                  &rsaquo; {item.text}
                </a>
              ))}
            </nav>
          </details>
        )}

        <div class="prose prose-neutral prose-invert max-w-none text-neutral-300 text-sm md:text-base leading-relaxed space-y-6">
          <Content />
        </div>

        <nav class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-16 pt-8 border-t border-neutral-900 font-sans text-xs uppercase" data-pagefind-ignore>
          <div>
            {prevPost && (
              <a href={getPostUrl(prevPost)} class="block terminal-card p-4 hover:border-accent/40 rounded-sm">
                <span class="text-text-secondary text-[10px] block mb-1">Previous</span>
                <span class="text-white text-xs block font-display font-semibold normal-case truncate">{prevPost.data.title}</span>
              </a>
            )}
          </div>
          <div class="text-right">
            {nextPost && (
              <a href={getPostUrl(nextPost)} class="block terminal-card p-4 hover:border-accent/40 rounded-sm">
                <span class="text-text-secondary text-[10px] block mb-1">Next</span>
                <span class="text-white text-xs block font-display font-semibold normal-case truncate">{nextPost.data.title}</span>
              </a>
            )}
          </div>
        </nav>

        <RelatedPosts posts={relatedPosts} />

        <div data-pagefind-ignore>
          <GiscusComments />
        </div>
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .prose h2 {
    font-family: var(--font-display);
    font-weight: 700;
    color: #ffffff;
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.25rem;
  }

  .prose h2::before {
    content: "// ";
    color: #b3001b;
  }

  .prose h3 {
    font-family: var(--font-display);
    font-weight: 700;
    color: #ffffff;
    font-size: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  .prose p {
    margin-bottom: 1.25rem;
  }

  .prose code {
    background-color: #1f1f2e;
    color: #ffffff;
    padding: 0.2rem 0.4rem;
    font-size: 0.85em;
    border-radius: 2px;
    font-family: var(--font-sans);
  }

  .prose pre {
    background-color: #1f1f2e !important;
    padding: 1rem;
    border-radius: 2px;
    font-size: 0.85em;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
    font-size: inherit;
    border-radius: 0;
    color: inherit;
  }

  .prose ul,
  .prose ol {
    margin-left: 1.5rem;
    margin-bottom: 1.25rem;
    list-style-type: square;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .prose th,
  .prose td {
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 0.6rem 0.8rem;
    text-align: left;
  }

  .prose th {
    background-color: #1f1f2e;
    color: white;
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prose blockquote {
    border-left: 2px solid #b3001b;
    padding-left: 1rem;
    color: #a8a8a8;
    font-style: italic;
    margin: 1.5rem 0;
  }
</style>
