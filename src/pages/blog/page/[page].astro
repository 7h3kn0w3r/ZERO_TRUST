---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts, paginatePosts, POSTS_PER_PAGE } from '../../../utils/blog';
import BlogListing from '../../../components/BlogListing.astro';

export async function getStaticPaths() {
  const allPosts = getPublishedPosts(await getCollection('blog'));
  const totalPages = Math.max(1, Math.ceil(allPosts.length / POSTS_PER_PAGE));

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => ({
    params: { page: String(index + 2) },
  }));
}

const page = Number(Astro.params.page);
const allPosts = getPublishedPosts(await getCollection('blog'));
const { items, currentPage, totalPages } = paginatePosts(allPosts, page, POSTS_PER_PAGE);

if (page < 2 || page > totalPages) {
  return Astro.redirect('/blog/');
}

const categories = ['All', ...new Set(allPosts.map((post) => post.data.category))];
const tags = ['All', ...new Set(allPosts.flatMap((post) => post.data.tags))];
---

<Layout title={`Writeups // Page ${currentPage} // Noir Trace`} description="Technical security writeups, reverse engineering logs, and malware analysis documents.">
  <BlogListing
    posts={items}
    categories={categories}
    tags={tags}
    currentPage={currentPage}
    totalPages={totalPages}
  />
</Layout>
