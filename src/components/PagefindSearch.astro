<div class="pagefind-search-container border border-neutral-800 bg-[#1F1F2E]/50 p-4 rounded-sm relative overflow-hidden backdrop-blur-sm">
  <div class="absolute top-0 left-0 w-1 h-full bg-[#B3001B]"></div>
  <div id="search"></div>
</div>

<!-- Load Pagefind assets statically -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<script is:inline>
  function initPagefind() {
    if (typeof PagefindUI !== 'undefined') {
      new PagefindUI({
        element: "#search",
        showSubResults: true,
        baseUrl: "/",
        bundlePath: "/pagefind/",
        showImages: false,
        translations: {
          placeholder: "Search writeups, tags, tools, or footprint logs..."
        }
      });
    } else {
      const searchEl = document.getElementById('search');
      if (searchEl) {
        searchEl.innerHTML = `
          <div class="text-neutral-400 font-mono text-xs space-y-1.5 p-2">
            <p><span class="text-[#B3001B] font-bold">[WARN]</span> SEARCH ENGINE OFFLINE: Index files not found in dev environment.</p>
            <p class="text-[10px] text-neutral-500">Run "npm run build" and "npx pagefind --site dist" to generate indices and preview search.</p>
          </div>
        `;
      }
    }
  }

  // Handle load and View Transitions if added later
  window.addEventListener('DOMContentLoaded', initPagefind);
  document.addEventListener('astro:after-swap', initPagefind);
</script>

<style is:global>
